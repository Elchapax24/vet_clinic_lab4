<h1>Appointments</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>

  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td>
          <%= link_to appointment.date.strftime("%B %d, %Y"), appointment_path(appointment) %>
        </td>
        <td><%= appointment.pet.name %></td>
        <td>
          <%= "#{appointment.vet.first_name} #{appointment.vet.last_name}" %>
        </td>
        <td><%= appointment.reason %></td>
        <td><%= ["Scheduled", "In Progress", "Completed", "Cancelled"][appointment.status] %></td>
      </tr>
    <% end %>
  </tbody>
</table>